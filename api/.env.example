# Cookslate Environment Configuration
# Copy this file to .env and update the values for your setup.

# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=crumble_db
DB_USER=root
DB_PASS=

# ─── App ──────────────────────────────────────────────────
# "production" hides errors and enables strict security headers
# "development" shows errors and relaxes CORS
APP_ENV=production

# Frontend URL(s) for CORS — comma-separated
CORS_ORIGINS=http://localhost:5176

# ─── SSL (optional) ──────────────────────────────────────
# Set if PHP/cURL can't find the system CA bundle
# CURL_CA_BUNDLE=/path/to/cacert.pem

# ─── SSO (optional) ──────────────────────────────────────
# For Authentik, Keycloak, or other OIDC providers
# Leave empty to disable SSO
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_PROVIDER_URL=

# ─── API Integrations (optional) ───────────────────────

# USDA FoodData Central — free nutrition data for 300k+ foods
# Get a key: https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=

# TheMealDB — recipe discovery (works without key, free tier)
# Premium key: https://www.themealdb.com/api.php (optional, for higher limits)
# MEALDB_API_KEY=1

# Open Food Facts — barcode/UPC product lookup (no key needed)
# Docs: https://world.openfoodfacts.org/data

# ─── Future integrations (add your own keys) ──────────
# Edamam Nutrition Analysis: https://developer.edamam.com/
# EDAMAM_APP_ID=
# EDAMAM_APP_KEY=
#
# Spoonacular: https://spoonacular.com/food-api
# SPOONACULAR_API_KEY=
